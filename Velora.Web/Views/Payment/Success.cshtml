@{
    ViewData["Title"] = "Payment Successful - Velora";
}

<div class="container py-5 mt-5 text-center">
    <div class="card border-0 shadow-sm rounded-4 p-5 mx-auto" style="max-width: 600px;">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success fs-1"></i>
        </div>
        <h2 class="fw-bold mb-3">Thank you for your order!</h2>
        <p class="text-muted mb-5">Your payment was processed successfully. We've sent a confirmation email to your inbox.</p>
        
        <div class="d-flex gap-3 justify-content-center">
            <a href="/" class="btn btn-velora px-4">Continue Shopping</a>
            <a href="#" class="btn btn-outline-dark px-4">Track Order</a>
        </div>
    </div>
</div>
