@model List<Velora.Web.Controllers.CartItem>
@{
    ViewData["Title"] = "Your Cart - Velora";
}

<div class="container py-5 mt-5">
    <h2 class="fw-bold mb-5">Your Shopping Cart</h2>

    <div class="row g-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr class="text-muted small text-uppercase">
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@item.ImageUrl" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                                <span class="fw-medium">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td>@item.Price.ToString("C2")</td>
                                        <td>
                                            <span class="px-3 py-1 border rounded">@item.Quantity</span>
                                        </td>
                                        <td class="fw-bold">@item.Total.ToString("C2")</td>
                                        <td>
                                            <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="text-danger"><i class="bi bi-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-bag-x fs-1 text-muted mb-3"></i>
                        <p class="text-muted">Your cart is empty.</p>
                        <a href="/" class="btn btn-velora mt-3">Start Shopping</a>
                    </div>
                }
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-light">
                    <h5 class="fw-bold mb-4">Order Summary</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Subtotal</span>
                        <span>@Model.Sum(i => i.Total).ToString("C2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4 fw-bold fs-5">
                        <span>Total</span>
                        <span>@Model.Sum(i => i.Total).ToString("C2")</span>
                    </div>
                    <a asp-controller="Payment" asp-action="CreateCheckoutSession" class="btn btn-velora w-100 py-3 text-center">Proceed to Checkout</a>
                </div>
            </div>
        }
    </div>
</div>
