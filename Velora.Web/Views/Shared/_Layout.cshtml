<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Velora</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/velora.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="container">
            <nav class="navbar navbar-expand-lg">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Velora</a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="bi bi-list fs-2"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="#">Shop</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Collections</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">New Arrivals</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Sustainability</a>
                        </li>
                    </ul>
                    
                    <div class="header-icons">
                        <i class="bi bi-search"></i>
                        <i class="bi bi-suit-heart"></i>
                        <i class="bi bi-person"></i>
                        <div class="position-relative">
                            <i class="bi bi-bag"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark" style="font-size: 0.6rem;">0</span>
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <a class="footer-brand" href="#">Velora</a>
                    <p class="text-muted small">© 2024 Velora. Atmospheric Minimalism for the modern lifestyle. All rights reserved.</p>
                </div>
                <div class="col-6 col-lg-2">
                    <h4 class="footer-links-title">Shop</h4>
                    <ul class="footer-links">
                        <li><a href="#">New Arrivals</a></li>
                        <li><a href="#">Collections</a></li>
                        <li><a href="#">Bestsellers</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h4 class="footer-links-title">Help</h4>
                    <ul class="footer-links">
                        <li><a href="#">Shipping & Returns</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h4 class="footer-links-title">Join our community</h4>
                    <p class="text-muted small mb-3">Newsletter için kayıt olun.</p>
                    <div class="d-flex gap-2">
                        <input type="email" class="newsletter-input m-0" placeholder="E-posta adresiniz">
                        <button class="btn btn-velora py-2" style="height: fit-content;">Kayıt Ol</button>
                    </div>
                </div>
            </div>
            <div class="mt-5 pt-4 border-top border-secondary opacity-25">
                <div class="d-flex justify-content-between small">
                    <div class="d-flex gap-3">
                        <i class="bi bi-instagram"></i>
                        <i class="bi bi-facebook"></i>
                        <i class="bi bi-pinterest"></i>
                    </div>
                    <span>Design Inspired by Atmospheric Minimalism</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

