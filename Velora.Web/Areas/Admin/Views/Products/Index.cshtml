@model IEnumerable<Velora.Core.Entities.Product>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Product Management";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h2 class="fw-bold m-0">Product Management</h2>
        <p class="text-muted">Manage your inventory and product listings.</p>
    </div>
    <a asp-action="Create" class="btn btn-dark px-4"><i class="bi bi-plus-lg"></i> Add New Product</a>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImageUrl" alt="@item.Name" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;">
                        </td>
                        <td class="fw-bold">@item.Name</td>
                        <td>@item.Category.Name</td>
                        <td>@item.Price.ToString("C2")</td>
                        <td>
                            <span class="badge @(item.StockQuantity > 5 ? "bg-success" : "bg-warning") bg-opacity-10 text-@(item.StockQuantity > 5 ? "success" : "warning")">
                                @item.StockQuantity units
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light">Edit</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
